# ── TalentSync AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your actual keys.

# App
APP_NAME=TalentSync AI
DEBUG=false

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here

# Database (SQLite — no changes needed)
DATABASE_URL=sqlite+aiosqlite:///./talentsync.db

# Anthropic Claude (required) — get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone (required) — get from: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=talentsync-jobs
